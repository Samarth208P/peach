# ═══════════════════════════════════════════════════════════════════════════════
# Peach Monorepo — Unified Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in your values.
# Both apps/keeper and apps/frontend load from this single file.

# ── Network ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUI_NETWORK=testnet

# ── Sui RPC (Keeper) ─────────────────────────────────────────────────────────
# Primary RPC endpoint
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Failover endpoints (comma-separated, format: url|weight)
# Higher weight = preferred. Keeper will auto-rotate on 504/timeout errors.
SUI_RPC_ENDPOINTS=https://fullnode.testnet.sui.io:443|10,https://rpc-testnet.suiscan.xyz|7,https://sui-testnet-rpc.publicnode.com:443|5

# RPC resilience settings (optional — defaults shown)
# RPC_REQUEST_TIMEOUT_MS=30000
# RPC_MAX_RETRIES=5
# RPC_BASE_RETRY_DELAY_MS=1000
# RPC_MAX_RETRY_DELAY_MS=30000

# ── Keeper Wallet ────────────────────────────────────────────────────────────
# Private key (hex without flag — from `sui keytool convert`)
KEEPER_PRIVATE_KEY=

# ── Peach v2 Package ─────────────────────────────────────────────────────────
PEACH_PACKAGE_ID=
NEXT_PUBLIC_PEACH_PACKAGE_ID=

PEACH_REGISTRY_ID=
NEXT_PUBLIC_PEACH_REGISTRY_ID=

KEEPER_CAP_OBJECT_ID=

# ── DeepBook V3 ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_DEEPBOOK_PACKAGE_ID=

DEEPBOOK_SUI_USDC_POOL_ID=
NEXT_PUBLIC_DEEPBOOK_SUI_USDC_POOL_ID=

NEXT_PUBLIC_DEEP_TOKEN_TYPE=

# ── Pyth Network ─────────────────────────────────────────────────────────────
PYTH_HERMES_URL=https://hermes.pyth.network
NEXT_PUBLIC_PYTH_HERMES_URL=https://hermes.pyth.network

PYTH_SUI_USD_FEED_ID=
NEXT_PUBLIC_PYTH_SUI_USD_FEED_ID=

PYTH_PRICE_INFO_OBJECT_ID=
NEXT_PUBLIC_PYTH_SUI_USD_PRICE_INFO_OBJECT_ID=

PYTH_STATE_ID=
NEXT_PUBLIC_PYTH_STATE_ID=

NEXT_PUBLIC_PYTH_PACKAGE_ID=

# ── Wormhole ─────────────────────────────────────────────────────────────────
WORMHOLE_STATE_ID=
NEXT_PUBLIC_WORMHOLE_STATE_ID=

# ── USDC Type (DeepBook DBUSDC on testnet) ───────────────────────────────────
USDC_TYPE=
NEXT_PUBLIC_USDC_TYPE=

# ── Keeper Operational Config ────────────────────────────────────────────────
PRICE_POLL_INTERVAL_MS=10000
GAS_BUDGET=100000000
LOW_BALANCE_ALERT_SUI=5000000000
DASHBOARD_PORT=3001
