{
  "name": "peach-monorepo",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@11.4.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:frontend": "npm run dev --workspace=apps/frontend",
    "dev:keeper": "npm run dev --workspace=@peach/keeper",
    "start": "turbo run start",
    "start:keeper": "npm run start --workspace=@peach/keeper",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^2.9.18"
  }
}
